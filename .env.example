# Public app origin used by the browser, Better Auth and CORS.
# Examples:
# APP_ORIGIN=http://89.108.78.121
# APP_ORIGIN=https://cook-book.fun
APP_ORIGIN=http://localhost

# Caddy site address.
# For plain HTTP by IP:
# CADDY_SITE_ADDRESS=http://89.108.78.121
# For automatic HTTPS by domain:
# CADDY_SITE_ADDRESS=cook-book.fun, www.cook-book.fun
CADDY_SITE_ADDRESS=http://localhost

# Backend auth secret. Generate a long random value in production.
BETTER_AUTH_SECRET=change-me-in-production

# Optional comma-separated admin emails.
ADMIN_EMAILS=

# Browser-facing API URL.
# Keep PUBLIC_API_BASE_URL empty so the browser uses same-origin /api.
PUBLIC_API_BASE_URL=

# Container-internal API URL for SvelteKit SSR.
INTERNAL_API_BASE_URL=http://server:3000

# Runtime database selection.
DATABASE_PROVIDER=postgres

# Current runtime database URL.
# For the default docker-compose PostgreSQL service:
DATABASE_URL=postgres://cookbook:cookbook@postgres:5432/cookbook

# Path to the legacy SQLite database used as a migration source.
SQLITE_MIGRATION_SOURCE=/app/data/recipe-book.db

# PostgreSQL container credentials used by docker-compose.
POSTGRES_DB=cookbook
POSTGRES_USER=cookbook
POSTGRES_PASSWORD=cookbook

# Reverse proxy headers passed to SvelteKit node adapter.
PROTOCOL_HEADER=x-forwarded-proto
HOST_HEADER=x-forwarded-host

# Optional port overrides.
HTTP_PORT=80
HTTPS_PORT=443
SERVER_PORT=3000
CLIENT_PORT=3001
SERVER_NODE_ENV=production
CLIENT_NODE_ENV=production
